[user]
  name = Tim Martin
  email = tim@timmart.in
	signingKey = 19A52622B91D5DE3

[color]
  ui = auto

[push]
  default = current
  followTags = true
  gpgSign = if-asked
  autoSetupRemote = true

[branch]
  autosetuprebase = always
  sort = -committerdate

[merge]
  conflictstyle = zdiff3

[fetch]
  prune = true
  pruneTags = true
  all = true

[core]
  editor = nvim
  pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true

[grep]
  lineNumber = true
  patternType = extended

[github]
  user = t-mart

[alias]
  logg = log --graph --format='%C(bold blue)%h%C(reset) %C(cyan)%>(12)%ar%C(reset)%C(auto)%d%C(reset) %<(80,trunc)%s %C(magenta)%aN%C(reset)'
  reflogg = reflog --date=relative --format='%C(bold blue)%h%C(reset) %C(bold yellow)%gd%C(reset)%C(auto)%d%C(reset) %<(80,trunc)%gs%n  ↳  %s - %C(magenta)%aN%C(reset)'

[rerere]
  enabled = true
  autoupdate = true

[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true

[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true

[init]
  defaultBranch = master

[commit]
  gpgSign = true
  verbose = true

[tag]
  gpgSign = true
  sort = version:refname

[help]
  autocorrect = prompt

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
