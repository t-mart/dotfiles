{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Non-Home Configuration",
  "type": "object",
  "required": ["copies"],
  "additionalProperties": false,
  "properties": {
    "copies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source", "dest"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name for this config file.",
            "minLength": 1
          },
          "reference_url": {
            "type": "string",
            "description": "Documentation URL shown with the post-copy steps.",
            "format": "uri"
          },
          "source": {
            "type": "string",
            "description": "Path relative to the non-home/ directory.",
            "minLength": 1
          },
          "dest": {
            "type": "string",
            "description": "Absolute destination path on the system.",
            "pattern": "^/"
          },
          "when": {
            "type": "object",
            "description": "Conditions that must all hold (AND) for this entry to apply. Omitted keys impose no constraint.",
            "additionalProperties": false,
            "properties": {
              "packages_installed": {
                "type": "array",
                "description": "Pacman packages that must all be installed.",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "after_commands": {
            "type": "array",
            "description": "Commands for the user to run after the file is copied.",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
