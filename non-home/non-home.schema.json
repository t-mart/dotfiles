{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Non-Home Configuration",
  "type": "object",
  "required": ["copies"],
  "additionalProperties": false,
  "properties": {
    "copies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source", "dest", "instructions"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name for this config file.",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "description": "Path relative to the non-home/ directory.",
            "minLength": 1
          },
          "dest": {
            "type": "string",
            "description": "Absolute destination path on the system.",
            "pattern": "^/"
          },
          "when": {
            "type": "object",
            "description": "Conditions that must all hold (AND) for this entry to apply. Omitted keys impose no constraint.",
            "additionalProperties": false,
            "properties": {
              "packages_installed": {
                "type": "array",
                "description": "Pacman packages that must all be installed.",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "instructions": {
            "type": "string",
            "description": "Post-copy instructions displayed to the user.",
            "minLength": 1
          }
        }
      }
    }
  }
}
